USE classicmodels;
/* 1. Highest purchase price product */
SELECT
buyPrice,
quantityInStock,
productName
FROM
products
ORDER BY
buyPrice DESC
LIMIT 1;
/* 2. Customers on 'Lane' with credit > 80k */
SELECT
customerName,
addressLine1,
creditLimit
FROM
customers
WHERE
(addressLine1 LIKE '%Lane%' OR addressLine1 LIKE '%Ln.%')
AND creditLimit > 80000;
/* 3. Products in >50 orders (descending) */
SELECT
p.productName,
p.productCode,
COUNT(od.orderNumber) AS orders_count
FROM
products p
JOIN
orderdetails od ON p.productCode = od.productCode
GROUP BY
p.productCode, p.productName
HAVING
orders_count > 50
ORDER BY
orders_count DESC;
/* 4. Payments > 100k in 2005 */
SELECT
c.customerName,
c.customerNumber,
p.amount
FROM
customers c
JOIN
payments p ON c.customerNumber = p.customerNumber
WHERE
YEAR(p.paymentDate) = 2005
AND p.amount > 100000;
/* 5. Payments managed by San Francisco office (sorted by date) */
SELECT
c.customerName,
p.paymentDate
FROM
customers c
JOIN
payments p ON c.customerNumber = p.customerNumber
JOIN
employees e ON c.salesRepEmployeeNumber = e.employeeNumber
JOIN
offices o ON e.officeCode = o.officeCode
WHERE
o.city = 'San Francisco'
ORDER BY
p.paymentDate;
/* 6. Payments on specific dates (Nov 15 or 17, 2004) */
SELECT 
c.customerName, 
c.customerNumber
FROM 
customers c
JOIN 
payments p ON c.customerNumber = p.customerNumber
WHERE 
p.paymentDate = '2004-11-15' 
OR p.paymentDate = '2004-11-17';
/* 7. 'Vintage' products containing 'tires' description */
SELECT * FROM products
WHERE productLine LIKE '%Vintage%' 
AND productDescription LIKE '%tires%';
/* 8. Japan employees with no assigned customers */
SELECT 
o.city AS department, 
e.firstName, 
e.lastName
FROM 
employees e
JOIN 
offices o ON e.officeCode = o.officeCode
LEFT JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
WHERE 
c.customerNumber IS NULL 
AND o.country = 'Japan';
/* 9. Office 6 employees with non-paying customers */
/* Note: Returns empty if all customers have paid */
SELECT DISTINCT 
e.*
FROM 
employees e
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
LEFT JOIN 
payments p ON c.customerNumber = p.customerNumber
WHERE 
e.officeCode = '6' 
AND p.checkNumber IS NULL;
/* 10. Employee count per office (descending) */
SELECT 
o.city AS department, 
COUNT(e.employeeNumber) AS employee_count
FROM 
offices o
JOIN 
employees e ON o.officeCode = e.officeCode
GROUP BY 
o.officeCode, o.city
ORDER BY 
employee_count DESC;
/* 11. Monthly order volume (Jan to Dec) */
SELECT 
MONTHNAME(orderDate) AS month_name, 
COUNT(orderNumber) AS total_orders
FROM 
orders
GROUP BY 
MONTH(orderDate), MONTHNAME(orderDate)
ORDER BY 
MONTH(orderDate);
/* 12. Employees managing high payments (>100k) */
SELECT DISTINCT 
e.employeeNumber, 
e.firstName, 
e.lastName
FROM 
employees e
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
JOIN 
payments p ON c.customerNumber = p.customerNumber
WHERE 
p.amount > 100000
ORDER BY 
e.employeeNumber;
/* 13. USA employees with no assigned customers */
SELECT 
e.employeeNumber, 
e.firstName, 
e.lastName, e.jobTitle
FROM 
employees e
JOIN 
offices o ON e.officeCode = o.officeCode
LEFT JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
WHERE 
o.country = 'USA' 
AND c.customerNumber IS NULL;
/* 14. Antiquity of the oldest order (Years passed) */
SELECT 
orderNumber, 
customerNumber, 
orderDate,
TIMESTAMPDIFF(YEAR, orderDate, NOW()) AS antiquity
FROM 
orders
ORDER BY 
orderDate ASC
LIMIT 1;
/* 15. Payment statistics (Total, Min, Max) */
SELECT 
COUNT(*) AS total_payments, 
MIN(amount) AS min_amount, 
MAX(amount) AS max_amount
FROM 
payments;
/* 16. Employees with customers making small payments (<3k) */
SELECT 
e.employeeNumber, 
e.firstName, 
COUNT(DISTINCT c.customerNumber) AS customer_count
FROM 
employees e
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
JOIN 
payments p ON c.customerNumber = p.customerNumber
WHERE 
p.amount < 3000
GROUP BY 
e.employeeNumber, e.firstName;
/* 17. NYC payments classification (High/Medium/Low) */
SELECT 
p.checkNumber, 
p.amount,
CASE 
WHEN p.amount > 50000 THEN 'Very high payment'
WHEN p.amount >= 15000 AND p.amount <= 50000 THEN 'Medium payment'
ELSE 'Low payment'
END AS payment_classification
FROM 
payments p
JOIN 
customers c ON p.customerNumber = c.customerNumber
JOIN 
employees e ON c.salesRepEmployeeNumber = e.employeeNumber
JOIN 
offices o ON e.officeCode = o.officeCode
WHERE 
o.city = 'NYC';
/* 18. Employee directory sorted by branch and name */
SELECT 
o.city AS branch_name, 
e.firstName, 
e.lastName
FROM 
employees e
JOIN 
offices o ON e.officeCode = o.officeCode
ORDER BY 
o.city, e.lastName;
/* 19. Office managing 'Atelier graphique' orders */
SELECT DISTINCT 
o.city AS office_name
FROM 
offices o
JOIN 
employees e ON o.officeCode = e.officeCode
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
JOIN 
orders ord ON c.customerNumber = ord.customerNumber
WHERE 
c.customerName = 'Atelier graphique';
/* 20. Non-Sales Rep employees and their boss */
SELECT 
e.firstName, 
e.lastName, 
e.jobTitle, 
CONCAT(b.firstName, ' ', b.lastName) AS boss_name
FROM 
employees e
LEFT JOIN 
employees b ON e.reportsTo = b.employeeNumber
WHERE 
e.jobTitle <> 'Sales Rep';
/* 21. Total revenue per office */
SELECT 
o.city AS office_name, 
SUM(od.quantityOrdered * od.priceEach) AS total_amount
FROM 
offices o
JOIN 
employees e ON o.officeCode = e.officeCode
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
JOIN 
orders ord ON c.customerNumber = ord.customerNumber
JOIN 
orderdetails od ON ord.orderNumber = od.orderNumber
GROUP BY 
o.officeCode, o.city;
/* 22. Japanese customers buying Classic Cars */
SELECT DISTINCT 
c.customerName, 
e.firstName,
e.lastName
FROM 
customers c
JOIN 
employees e ON c.salesRepEmployeeNumber = e.employeeNumber
JOIN 
orders ord ON c.customerNumber = ord.customerNumber
JOIN 
orderdetails od ON ord.orderNumber = od.orderNumber
JOIN 
products p ON od.productCode = p.productCode
WHERE 
c.country = 'Japan' 
AND p.productLine = 'Classic Cars';
/* 23. Office cities with high-load employees (>=5 customers) */
SELECT DISTINCT 
o.city AS office_city
FROM 
offices o
JOIN 
employees e ON o.officeCode = e.officeCode
WHERE 
e.employeeNumber IN (
SELECT salesRepEmployeeNumber
FROM customers
GROUP BY salesRepEmployeeNumber
HAVING COUNT(customerNumber) >= 5
);
/* 24 (A). Strict Interpretation: Orders in May 2024 (Returns empty) */
SELECT 
ord.orderNumber, 
ord.orderDate
FROM 
orders ord
JOIN 
orderdetails od ON ord.orderNumber = od.orderNumber
JOIN 
products p ON od.productCode = p.productCode
WHERE 
p.productLine = 'Planes'
AND YEAR(ord.orderDate) = 2024 AND MONTH(ord.orderDate) = 5
AND ord.customerNumber IN (
SELECT customerNumber
FROM orders
GROUP BY customerNumber
HAVING COUNT(orderNumber) = 2
);
/* 24 (B). Logical Interpretation: Orders in May 2004 (Typo correction) */
SELECT 
ord.orderNumber, 
ord.orderDate
FROM 
orders ord
JOIN 
orderdetails od ON ord.orderNumber = od.orderNumber
JOIN 
products p ON od.productCode = p.productCode
WHERE 
p.productLine = 'Planes'
AND YEAR(ord.orderDate) = 2004 AND MONTH(ord.orderDate) = 5
AND ord.customerNumber IN (
SELECT customerNumber
FROM orders
GROUP BY customerNumber
HAVING COUNT(orderNumber) = 2
);
/* 25. Customer count by city and order status */
SELECT 
o.city AS office_city, 
ord.status AS order_status, 
COUNT(DISTINCT c.customerNumber) AS customer_count
FROM 
offices o
JOIN 
employees e ON o.officeCode = e.officeCode
JOIN 
customers c ON e.employeeNumber = c.salesRepEmployeeNumber
JOIN 
orders ord ON c.customerNumber = ord.customerNumber
GROUP BY 
o.city, ord.status
ORDER BY 
o.city, ord.status;